# Server port
PORT=8080

# Matchmaking API (Lambda) - invoked when game starts (assigns roles)
# Falls back to VITE_API_URL if not set
MATCHMAKING_API_URL=

# Secret for start action - must match Lambda's START_GAME_SECRET
MATCHMAKING_API_SECRET=

# AWS (required for DynamoDB lobby validation)
AWS_REGION=us-west-2
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
